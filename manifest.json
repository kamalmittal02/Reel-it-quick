{
  "manifest_version": 3,
  "name": "Reel It Quick",
  "version": "1.2.0",
  "description": "Auto-load, search, filter, and group an Instagram profile's recent Reels by hashtag.",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Reel It Quick — open on instagram.com"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["src/extractor.js", "src/content.js"],
      "css": ["src/panel.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
