{
  "manifest_version": 3,
  "name": "Reel It Quick",
  "version": "1.2.0",
  "description": "Auto-load, search, filter, and group an Instagram profile's recent Reels by hashtag.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "reel-it-quick@kamalmittal02.github.io",
      "strict_min_version": "128.0"
    }
  },
  "permissions": ["scripting"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://instagram.com/*"
  ],
  "background": {
    "scripts": ["src/background.js"]
  },
  "action": {
    "default_title": "Reel It Quick — open on instagram.com",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["src/extractor.js", "src/content.js"],
      "css": ["src/panel.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
